{
  "name": "@sylphx/db-proxy",
  "version": "1.0.0",
  "description": "Database proxy — SNI/TLS + plaintext routing for PostgreSQL and MySQL",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "dependencies": {
    "postgres": "3.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.1.0",
    "typescript": "^5.8.0"
  }
}
